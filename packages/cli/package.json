{
  "name": "popcoru",
  "version": "0.13.0",
  "description": "Agent Workspace OS — harness engineering for AI coding agents",
  "type": "module",
  "files": [
    "bin/",
    "commands/",
    "dist/",
    "docs/",
    "hooks/",
    "agents/",
    "workflows/",
    "references/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "popcoru": "./bin/install.cjs",
    "sunco": "./bin/install.cjs",
    "sunco-runtime": "./bin/sunco-runtime.cjs"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "harness-engineering",
    "cli",
    "typescript",
    "lint",
    "verification"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minkyungwook/sunco.git"
  },
  "homepage": "https://github.com/minkyungwook/sunco#readme",
  "bugs": {
    "url": "https://github.com/minkyungwook/sunco/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "node bin/smoke-test.cjs --runtime claude",
    "test:codex": "node bin/smoke-test.cjs --runtime codex",
    "test:all": "node bin/smoke-test.cjs --runtime claude && node bin/smoke-test.cjs --runtime codex",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "node bin/contract-lint.cjs",
    "test:artifact": "node bin/release-artifact-smoke.cjs",
    "prepack": "npm run build && npm run lint"
  },
  "dependencies": {
    "commander": "14.0.3",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@sunco/core": "*",
    "@sunco/edit-engine": "*",
    "@sunco/evidence": "*",
    "@sunco/runtime": "*",
    "@sunco/skills-harness": "*",
    "@sunco/skills-workflow": "*",
    "@sunco/verifier": "*",
    "@types/node": "25.5.0",
    "tsup": "8.5.0",
    "typescript": "6.0.2"
  }
}
