{
  "name": "sunco-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "react": "19.1.0",
    "turbo": "2.5.4",
    "typescript": "6.0.2"
  },
  "overrides": {
    "typescript-eslint": {
      "typescript": "$typescript"
    },
    "@typescript-eslint/typescript-estree": {
      "typescript": "$typescript"
    },
    "@typescript-eslint/parser": {
      "typescript": "$typescript"
    }
  }
}
